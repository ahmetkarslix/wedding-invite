# ---------------------------------------------------------------------------
# Bu dosyayı ".env.local" olarak kopyalayıp değerleri doldurun.
# .env.local git'e gönderilmez (gizli kalır).
# ---------------------------------------------------------------------------

# Supabase — proje panelinden: Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # "service_role" anahtarı (GİZLİ — yalnız sunucuda)

# Admin paneli (/admin) için paylaşımlı şifre
ADMIN_PASSWORD=cok-gizli-bir-sifre

# Oturum çerezini imzalamak için rastgele, en az 32 karakterlik gizli anahtar
# Üretmek için: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_COOKIE_SECRET=buraya-rastgele-uzun-bir-deger
